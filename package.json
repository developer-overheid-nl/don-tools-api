{
  "name": "tools-api-v1",
  "version": "1.0.0",
  "description": "API van het Tools (apis.developer.overheid.nl)",
  "main": "dist/app/index.js",
  "scripts": {
    "init-install": "npm install",
    "dev": "tsx watch --env-file=.env app/index.ts",
    "dev-mock": "OPENAPI_MOCK=true npm run dev",
    "prebuild": "rm -rf dist",
    "build": "tsc",
    "start": "node --env-file-if-exists=.env dist/app/index.js",
    "test": "vitest run",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "license": "EUPL-1.2",
  "private": true,
  "dependencies": {
    "@developer-overheid-nl/don-tools-logic": "git+https://github.com/developer-overheid-nl/don-tools-api-v2.git#60-tools-api-refactor",
    "@fastify/cors": "^11.2.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "ajv-formats": "^3.0.1",
    "fastify": "^5.8.5",
    "js-yaml": "^4.2.0",
    "openapi-backend": "^5.17.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "js-yaml@>=4.0.0 <4.1.1": "4.2.0",
    "lodash@<=4.17.23": "4.18.1",
    "uuid@<11.1.1": "14.0.0",
    "yaml@>=1.0.0 <1.10.3": "2.9.0"
  }
}
